<component>
	<previews>
		<preview width="200" height="200" />
	</previews>
	<styles>
		<style
			name="style_main"
			width="200"
			height="200"
			radius="0"
			border_width="0"
			pad_all="0"
			pad_top="10"
			layout="flex"
			flex_flow="column"
			flex_main_place="center"
			flex_track_place="center"
			flex_cross_place="center"
			text_font="NS_Bold_20"
		/>
		<style name="style_cont" width="154" height="154" border_width="2" border_color="0x000000" radius="0" />
	</styles>
	<api>
		<prop name="image" type="image" default="watchface_default" />
		<prop name="name" type="string" default="Default" />
	</api>
	<view scrollable="false">
		<style name="style_main" />
		<lv_image src="$image">
			<style name="style_cont" />
		</lv_image>
		<lv_label text="$name" />
	</view>
</component>
