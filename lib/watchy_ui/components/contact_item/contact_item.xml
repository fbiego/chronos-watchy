	<view scroll_one="true" snappable="true">
		<style name="style_main" />
		<lv_label text="$name" style_text_font="NS_Bold_20" />
		<lv_label align="bottom_left" text="$number" />
		<lv_image align="right_mid" src="ic_sos" hidden="$normal" />
