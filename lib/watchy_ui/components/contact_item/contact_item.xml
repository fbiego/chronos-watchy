			name="style_main"
			width="190"
			height="50"
			pad_all="5"
			text_font="NS_Regular_20"
			border_width="1"
			border_side="bottom"
			border_color="0x000000"
			radius="0"
		/>
	</styles>
	<api>
		<prop name="name" type="string" default="Name" />
