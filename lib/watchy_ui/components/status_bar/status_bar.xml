<component>
	<previews>
		<preview width="200" height="200" />
	</previews>
	<styles>
		<style
			name="style_main"
			width="200"
			height="22"
			radius="0"
			border_width="1"
			border_color="0x000000"
			border_side="bottom"
			pad_all="0"
			pad_top="0"
			pad_left="5"
			pad_right="5"
			pad_column="5"
			layout="flex"
			flex_track_place="center"
			flex_cross_place="center"
			text_font="NS_Regular_16"
		/>
