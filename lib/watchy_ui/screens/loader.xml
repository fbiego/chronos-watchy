<screen>
	<styles>
		<style name="style_main" text_font="NS_Regular_16" bg_color="0xffffff" />
		<style
			name="style_cont"
			width="100%"
			height="175"
			pad_all="0"
			pad_row="0"
			border_width="0"
			text_color="0x000000"
			text_font="NS_Regular_16"
		/>
		<style name="style_list" layout="flex" flex_flow="column" />
	</styles>
	<view>
		<style name="style_main" />
		<status_bar />

		<lv_label
			name="c_info"
			width="180"
			align="center"
			text="There are no files available on the flash storage"
			style_text_font="NS_Regular_20"
		/>

		<lv_obj name="file_list" y="25" scrollbar_mode="off">
			<style name="style_cont" />
			<style name="style_list" />
			<file_item checked="true" />
			<file_item />
			<file_item />
			<file_item />
			<file_item />
			<file_item />
			<file_item />
		</lv_obj>
	</view>
</screen>
