<screen>
	<styles>
		<style name="style_main" text_font="NS_Regular_16" bg_color="0xffffff" />
	</styles>
	<view>
		<style name="style_main" />
		<status_bar />

		<lv_label
			width="180"
			y="40"
			x="10"
			text="Music Control&#10;Connected"
			bind_text="subject_bluetooth_state"
			bind_text-fmt="Music Control&#10;%s"
			style_text_font="NS_Bold_20"
		/>
		<lv_label
			y="-55"
			width="170"
			align="bottom_mid"
			text="Long press to change controls between track &amp; volume"
			style_text_align="center"
		/>
		<lv_label y="-5" align="bottom_mid" text="Double tap&#10;for next" style_text_align="center" />
		<lv_image src="ic_previous" align="top_right" x="-5" y="30">
			<bind_flag_if_not_eq flag="hidden" subject="subject_music_view" ref_value="0" />
		</lv_image>
		<lv_image src="ic_next" align="bottom_right" x="-5" y="-5">
			<bind_flag_if_not_eq flag="hidden" subject="subject_music_view" ref_value="0" />
		</lv_image>
		<lv_image src="ic_pause" align="bottom_left" x="5" y="-5">
			<bind_flag_if_not_eq flag="hidden" subject="subject_music_view" ref_value="0" />
		</lv_image>
		<lv_image src="ic_volume_up" align="top_right" x="-5" y="30">
			<bind_flag_if_not_eq flag="hidden" subject="subject_music_view" ref_value="1" />
		</lv_image>
		<lv_image src="ic_volume_down" align="bottom_right" x="-5" y="-5">
			<bind_flag_if_not_eq flag="hidden" subject="subject_music_view" ref_value="1" />
		</lv_image>
		<lv_image src="ic_mute" align="bottom_left" x="5" y="-5">
			<bind_flag_if_not_eq flag="hidden" subject="subject_music_view" ref_value="1" />
		</lv_image>
	</view>
</screen>
