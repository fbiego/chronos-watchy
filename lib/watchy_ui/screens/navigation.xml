<screen>
	<styles>
		<style name="style_main" text_font="NS_Regular_16" bg_color="0xffffff" />
		<style
			name="style_panel"
			width="100%"
			height="175"
			radius="0"
			border_width="0"
			pad_all="0"
			pad_top="5"
			pad_row="5"
			layout="flex"
			flex_flow="column"
			flex_cross_place="center"
			text_align="center"
			text_font="NS_Regular_16"
		/>
		<style
			name="style_cont"
			width="48"
			height="48"
			radius="0"
			border_color="0x000000"
			pad_all="0"
			border_width="0"
			bg_image_src="ic_chronos_40"
		/>
	</styles>
	<view>
		<style name="style_main" />
		<status_bar />
		<lv_obj y="25">
			<style name="style_panel" />
			<lv_label width="100%" name="n_text" text="10:20 ETA&#10;5 mins | 1.6km" />
			<lv_label width="100%" name="n_distance" text="100m" style_text_font="NS_Bold_20" />
			<lv_obj name="n_icon">
				<style name="style_cont" />
			</lv_obj>
			<lv_label width="100%" name="n_direction" text="Turn left towards Kenyatta avenue at the round about" />
		</lv_obj>
	</view>
</screen>
